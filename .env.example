# Template for local secrets. Copy to .env and fill in real values:
#   cp .env.example .env
# The .env file is gitignored; this .env.example is committed as documentation.
# .NET maps the double-underscore (__) to nested config keys.

ConnectionStrings__DefaultConnection=Host=localhost;Database=SRJdb;Username=postgres;Password=<your-password>

Jwt__Key=<your-jwt-signing-key-min-32-chars>
